{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HPN VPN",
  "version": "0.1.1",
  "identifier": "io.hpn.vpn.macos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "HPN VPN",
        "width": 520,
        "height": 780,
        "resizable": true,
        "minWidth": 480,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["dmg", "app"],
    "publisher": "HMSX Solutions",
    "copyright": "© 2026 HMSX Solutions. All rights reserved.",
    "category": "Utility",
    "shortDescription": "Post-Quantum VPN — ML-KEM + X25519 hybrid encryption",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "frameworks": [],
      "entitlements": "entitlements.plist",
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5NzA3QkI4QjI2Q0FBMTQKUldRVXFteXl1SHR3cWF1RHNwV1RNRDJIS2JydEg0VWZjQzhUOE5sQXQyTVAxV0Q5T1NUZ1BuMWYK",
      "endpoints": [
        "https://pkg.hpn.hmsx.io/latest.json"
      ]
    }
  }
}
